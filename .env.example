# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="your_hosted_backend_url_here"

# NODE_ENV: Server mode (development or production)
NODE_ENV="production"
PORT=3000

# SUPABASE DEPLOYMENT CONFIGS (BACKEND)
# Used in server.ts to establish real-time order broadcasts
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-role-key-here"

# OPTIONAL: Use your service_role secret key on the backend to completely bypass Row-Level Security (RLS) constraints
SUPABASE_SERVICE_ROLE_KEY=

# SUPABASE DB CONNECTION STRINGS (BACKEND)
# Used to configure connection to public PostgreSQL schemas
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# VITE CLIENT CONFIGS (FRONTEND)
# Used in the browser to receive and process real-time streams
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-role-key-here"
VITE_ENABLE_REAL_OTP="false"

# FIREBASE CONFIGS (SMS OTP, GOOGLE POPUP & EMAIL AUTH)
# These are loaded as fallbacks if firebase-applet-config.json is absent
FIREBASE_API_KEY="AIzaSyYourApiKeyHere"
FIREBASE_AUTH_DOMAIN="swiftcart-project.firebaseapp.com"
FIREBASE_PROJECT_ID="swiftcart-project"
FIREBASE_STORAGE_BUCKET="swiftcart-project.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="123456789"
FIREBASE_APP_ID="1:123456:web:123abc456"

# ADMIN PANEL SECURE PASSWORD
ADMIN_PASSWORD="admin_secure_pass_123"

